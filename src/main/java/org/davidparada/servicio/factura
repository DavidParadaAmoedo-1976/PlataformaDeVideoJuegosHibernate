package org.davidparada.servicio;

import com.itextpdf.kernel.pdf.PdfWriter;
import com.itextpdf.kernel.pdf.PdfDocument;
import com.itextpdf.layout.Document;
import com.itextpdf.layout.element.Paragraph;
import com.itextpdf.layout.element.Table;
import com.itextpdf.layout.properties.TextAlignment;
import org.davidparada.modelo.dto.FacturaDto;

import java.io.FileNotFoundException;
import java.time.ZoneId;
import java.time.format.DateTimeFormatter;

public class PdfServicio {

    public String generarFacturaPDF(FacturaDto factura) {
        String ruta = "facturas/factura_" + factura.numeroFactura() + ".pdf";

        try {
            PdfWriter writer = new PdfWriter(ruta);
            PdfDocument pdf = new PdfDocument(writer);
            Document document = new Document(pdf);

            // Título
            Paragraph titulo = new Paragraph("FACTURA")
                    .setBold()
                    .setFontSize(20)
                    .setTextAlignment(TextAlignment.CENTER);

            document.add(titulo);

            // Datos
            document.add(new Paragraph("Cliente: " + factura.nombreReal()));
            document.add(new Paragraph("Email: " + factura.email()));
            document.add(new Paragraph("Factura Nº: " + factura.numeroFactura()));

            // Fecha bonita
            DateTimeFormatter fecha =
                    DateTimeFormatter.ofPattern("dd/MM/yyyy HH:mm")
                            .withZone(ZoneId.systemDefault());
            DateTimeFormatter zona =
                    DateTimeFormatter.ofPattern("VV")
                            .withZone(ZoneId.systemDefault());

            document.add(new Paragraph("Zona Horaria: " + zona.format(factura.fechaEmision())));
            document.add(new Paragraph("Fecha: " + fecha.format(factura.fechaEmision())));

            // Espacio
            document.add(new Paragraph("\n"));

            // Tabla
            Table tabla = new Table(new float[]{250, 150, 150});

            tabla.addHeaderCell(new Paragraph("Producto").setBold());
            tabla.addHeaderCell(new Paragraph("Cantidad").setBold());
            tabla.addHeaderCell(new Paragraph("Precio").setBold());

            tabla.addCell("Juego");
            tabla.addCell("1");
            tabla.addCell(factura.importe() + "€");

            document.add(tabla);

            // Total
            Paragraph total = new Paragraph("TOTAL: " + factura.importe() + "€")
                    .setBold()
                    .setFontSize(14)
                    .setTextAlignment(TextAlignment.RIGHT);

            document.add(total);
            document.close();


            return ruta;
        } catch (FileNotFoundException e) {
            throw new RuntimeException(e);
        }
    }
}